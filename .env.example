# Supabase (free tier) — create a project at https://supabase.com, then copy
# Project URL + anon/public key from: Project Settings → API.
# Copy this file to `.env.local` and fill in the real values.
# These are exposed to the browser by design; data is protected by Row Level Security.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
